# Copy this to .env for local development
# On Render, set these in the Environment tab — never commit .env

# Render provides this automatically when you link a Postgres database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# A secret string you make up — used to protect your API
# Use the same value in the frontend VITE_API_KEY
API_KEY=make-up-a-long-random-string-here

# Your frontend URL (set this after you deploy the frontend)
FRONTEND_URL=https://your-app-name.onrender.com

PORT=4000
